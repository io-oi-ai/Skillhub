{
  "compilerOptions": {
    "target": "ES2019",
    "module": "commonjs",
    "moduleResolution": "node",
    "rootDir": "src",
    "outDir": "dist",
    "esModuleInterop": true,
    "preserveShebang": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "src/cli/**/*.ts",
    "src/lib/points.ts",
    "src/lib/types.ts",
    "src/lib/eval.ts"
  ]
}
